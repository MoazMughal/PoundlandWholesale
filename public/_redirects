# Redirect www to non-www
https://www.poundlandwholesale.com/* https://poundlandwholesale.com/:splat 301!

# Serve static files with correct content-type
/sitemap.xml /sitemap.xml 200!
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600

/robots.txt /robots.txt 200!
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/favicon-v3.png /favicon-v3.png 200!
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable

/site.webmanifest /site.webmanifest 200!
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=86400

/browserconfig.xml /browserconfig.xml 200!
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=86400

# SPA fallback - serve index.html for all other routes
/* /index.html 200