# Server Environment Variables

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/amazon-gymkhana
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/amazon-gymkhana

# JWT Secret (change this to a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Port
PORT=5000

# Email Configuration (Gmail)
# IMPORTANT: For Gmail, you need to use an "App Password", not your regular password
# Steps to get Gmail App Password:
# 1. Go to Google Account Settings
# 2. Enable 2-Factor Authentication
# 3. Go to Security > App Passwords
# 4. Generate a new app password for "Mail"
# 5. Use that 16-character password below

EMAIL_HOST=smtp.gmail.com
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM_NAME=Amazon Gymkhana

# Alternative Email Services:
# For SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_USER=apikey
# EMAIL_PASS=your-sendgrid-api-key

# For Mailgun:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_USER=your-mailgun-smtp-username
# EMAIL_PASS=your-mailgun-smtp-password

# WhatsApp Configuration (Optional - for OTP via WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Payment Gateway (Paymob - Optional)
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=your-paymob-integration-id

# Environment
NODE_ENV=development
# For production: NODE_ENV=production
